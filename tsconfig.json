{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "upload",
    "examples",
    "skills",
    "**/__tests__/**",
    "prisma/seed.ts",
    "src/lib/repositories",
    "src/lib/storage",
    "src/lib/services/ai.service.ts",
    "src/lib/services/notification.service.ts",
    "src/lib/services/player.service.ts",
    "src/lib/services/social.service.ts",
    "src/lib/services/video.service.ts",
    "src/lib/services/training.service.ts",
    "src/lib/ai/providers/speech.provider.ts",
    "src/lib/ai/pipeline.ts"
  ]
}