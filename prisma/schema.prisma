generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  position    String   @default("guard") // guard, forward, center
  level       String   @default("beginner") // beginner, intermediate, advanced, elite
  goals       String   @default("general") // shooting, ball_handling, defense, conditioning, general
  onboarding  Boolean  @default(false)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // XP & Leveling
  xp          Int      @default(0)
  xpLevel     Int      @default(1)

  // User preferences
  weeklyGoalSessions Int @default(3)
  weeklyGoalReps     Int @default(50)
  preferredRestSec   Int @default(15)
  soundEnabled       Boolean @default(true)
  hapticsEnabled     Boolean @default(true)
  language           String  @default("fr") // fr, en

  // Notification preferences
  notifStreak        Boolean @default(true)
  notifChallenge     Boolean @default(true)
  notifAchievement   Boolean @default(true)

  sessions      WorkoutSession[]
  favorites     DrillFavorite[]
  customDrills  Drill[]
  trainingPlans TrainingPlan[]
  xpLogs        XpLog[]
}

model Drill {
  id          String   @id @default(cuid())
  playerId    String?   // nullable — only set for custom drills; seed drills have no owner
  name        String
  nameFr      String
  category    String   // pocket_ball, shifty, ball_handling, speed_change, defense, shooting, footwork, finishing, conditioning
  difficulty  String   @default("beginner") // beginner, intermediate, advanced
  description String
  descriptionFr String
  instructions String
  instructionsFr String
  durationSec Int      @default(30)
  targetReps  Int      @default(10)
  icon        String   @default("🎯")
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())

  player              Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  favorites           DrillFavorite[]
  sessions            WorkoutSessionDrill[]
  trainingPlanDrills  TrainingPlanDrill[]

  @@index([playerId])
}

model WorkoutSession {
  id          String   @id @default(cuid())
  playerId    String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  totalScore  Float    @default(0)
  totalReps   Int      @default(0)
  totalDrills Int      @default(0)
  notes       String?

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drills      WorkoutSessionDrill[]

  @@index([playerId])
  @@index([startedAt])
}

model WorkoutSessionDrill {
  id          String   @id @default(cuid())
  sessionId   String
  drillId     String
  reps        Int      @default(0)
  score       Float    @default(0)
  durationMs  Int      @default(0)
  formFeedback String  @default("{}")
  createdAt   DateTime @default(now())

  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  drill       Drill         @relation(fields: [drillId], references: [id])

  @@index([sessionId])
  @@index([drillId])
}

model DrillFavorite {
  id          String   @id @default(cuid())
  playerId    String
  drillId     String
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drill       Drill    @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@unique([playerId, drillId])
  @@index([playerId])
}

model TrainingPlan {
  id          String   @id @default(cuid())
  playerId    String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drills      TrainingPlanDrill[]

  @@index([playerId])
}

model TrainingPlanDrill {
  id          String   @id @default(cuid())
  planId      String
  drillId     String
  order       Int      @default(0)
  targetReps  Int      @default(10)
  targetSets  Int      @default(1)
  restSec     Int      @default(30)
  createdAt   DateTime @default(now())

  plan        TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  drill       Drill        @relation(fields: [drillId], references: [id])

  @@unique([planId, drillId])
  @@index([planId])
  @@index([drillId])
}

model Achievement {
  id          String   @id @default(cuid())
  playerId    String
  type        String   // first_workout, drills_mastered, streak, score_milestone, etc.
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())

  @@unique([playerId, type])
  @@index([playerId])
}

model XpLog {
  id          String   @id @default(cuid())
  playerId    String
  amount      Int
  source      String   // workout, streak, achievement, challenge, bonus
  description String
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
}