// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCTION POSTGRESQL SCHEMA
// Basketball AI App — Production-ready PostgreSQL schema with UUIDs,
// native JSON types, snake_case table names, and optimized indexes.
//
// Usage: prisma generate --schema=prisma/schema.postgres.prisma
//        prisma migrate dev --schema=prisma/schema.postgres.prisma
// ═══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLAYER — Core user model
// ═══════════════════════════════════════════════════════════════════════════════

model Player {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  password    String
  name        String
  bio         String    @default("") @db.Text
  position    String    @default("guard")
  level       String    @default("beginner")
  goals       String    @default("general")
  onboarding  Boolean   @default(false) @db.Boolean
  avatar      String?
  coverPhoto  String?
  city        String?
  country     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // XP & Leveling
  xp          Int       @default(0)
  xpLevel     Int       @default(1)

  // Gamification
  streakFreezes       Int      @default(1)

  // User preferences
  weeklyGoalSessions Int @default(3)
  weeklyGoalReps     Int @default(50)
  preferredRestSec   Int @default(15)
  soundEnabled       Boolean @default(true) @db.Boolean
  hapticsEnabled     Boolean @default(true) @db.Boolean
  language           String  @default("fr")

  // Notification preferences
  notifStreak        Boolean @default(true) @db.Boolean
  notifChallenge     Boolean @default(true) @db.Boolean
  notifAchievement   Boolean @default(true) @db.Boolean
  notifSocial        Boolean @default(true) @db.Boolean
  notifMessage       Boolean @default(true) @db.Boolean

  // Authorization
  role               String   @default("user") // 'user' | 'admin'

  // Auth & Security
  resetToken         String?
  resetTokenExpiresAt DateTime?
  emailVerified      Boolean @default(false) @db.Boolean
  twoFactorEnabled   Boolean @default(false) @db.Boolean
  twoFactorSecret    String?
  accountDeleted     Boolean @default(false) @db.Boolean
  deletedAt          DateTime?

  // Privacy
  profilePublic      Boolean @default(true) @db.Boolean
  showOnLeaderboard  Boolean @default(true) @db.Boolean
  showActivity       Boolean @default(true) @db.Boolean

  // Counts (denormalized for performance)
  friendsCount       Int      @default(0)
  followersCount     Int      @default(0)
  followingCount     Int      @default(0)
  postsCount         Int      @default(0)
  videosCount        Int      @default(0)

  // Relations — Core
  sessions            WorkoutSession[]
  favorites           DrillFavorite[]
  customDrills        Drill[]
  trainingPlans       TrainingPlan[]
  xpLogs              XpLog[]
  reactionScores      ReactionScore[]
  aiChatMessages      AIChatMessage[]
  achievements        Achievement[]
  dailyLogins         DailyLogin[]

  // Relations — Social
  sentFriendRequests     Friendship[]          @relation("SentRequests")
  receivedFriendRequests Friendship[]          @relation("ReceivedRequests")
  teamMemberships        TeamMember[]
  ownedTeams             Team[]                @relation("TeamOwner")
  createdChallenges      Challenge[]
  challengeParticipants  ChallengeParticipant[]
  feedPosts              FeedPost[]
  postLikes              FeedPostLike[]
  comments               Comment[]
  commentReplies         CommentReply[]
  sentMessages           Message[]             @relation("SentMessages")
  conversations          ConversationMember[]
  following              Follow[]              @relation("Following")
  followers              Follow[]              @relation("Followers")
  liveSessions           LiveSession[]
  liveParticipations     LiveParticipant[]
  notifications          Notification[]

  // Relations — Video
  sessionComments       SessionComment[]
  videos                Video[]
  videoAnnotations      VideoAnnotation[]
  videoExports          VideoExport[]

  // Relations — AI
  poseData              PoseData[]
  shotDetections        ShotDetection[]
  formAnalyses          FormAnalysis[]
  playerInsights        PlayerInsight[]
  playerDocuments       PlayerDocument[]
  voiceSessions         VoiceSession[]
  predictions           Prediction[]
  generatedWorkouts     GeneratedWorkout[]

  // Subscription / Billing
  subscriptionStatus    String    @default("free") // 'free' | 'pro' | 'elite'
  subscriptionId        String?
  subscriptionExpiresAt DateTime?
  stripeCustomerId      String?

  // Relations — Subscription & Refresh Token (new)
  subscriptions         Subscription[]
  refreshTokens         RefreshToken[]

  // Referral
  referralCode          String?
  referredBy            String?

  // Player Stats (denormalized skill ratings)
  shooting              Int       @default(0)
  handling              Int       @default(0)
  finishing             Int       @default(0)
  defense               Int       @default(0)
  iq                    Int       @default(0)

  // Physical profile
  age                   Int?
  weightKg              Int?
  heightCm              Int?
  yearsExp              Int?

  // Streak tracking
  currentStreak         Int       @default(0)
  lastActivityDate      DateTime?

  // Active training plan (native JSON)
  activePlanJson        Json?

  // Onboarding status
  isOnboarded           Boolean   @default(false) @db.Boolean

  // Relations — Core
  emailTokens           EmailVerificationToken[]
  twoFactorBackupCodes  TwoFactorBackupCode[]
  devices               Device[]
  offlineActions        OfflineAction[]

  @@index([resetToken])
  @@index([email])
  @@index([twoFactorSecret])
  @@index([referralCode])
  @@index([referredBy])
  @@index([stripeCustomerId])
  @@index([subscriptionStatus])
  @@map("players")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBSCRIPTION — Stripe billing (new model)
// ═══════════════════════════════════════════════════════════════════════════════

model Subscription {
  id                    String    @id @default(uuid()) @db.Uuid
  playerId              String    @db.Uuid
  stripeSubscriptionId  String    @unique
  stripePriceId         String?
  stripeProductId       String?
  status                String    // active, past_due, canceled, trialing
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false) @db.Boolean
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// REFRESH TOKEN — JWT refresh token storage (new model)
// ═══════════════════════════════════════════════════════════════════════════════

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  token       String    @unique
  playerId    String    @db.Uuid
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  deviceInfo  String?   @db.Text

  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEBHOOK EVENT — Stripe webhook event log (new model)
// ═══════════════════════════════════════════════════════════════════════════════

model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @unique
  type        String
  payload     Json
  processed   Boolean   @default(false) @db.Boolean
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([processed])
  @@map("webhook_events")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DRILLS & TRAINING — Core workout system
// ═══════════════════════════════════════════════════════════════════════════════

model Drill {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String?  @db.Uuid
  name          String
  nameFr        String
  category      String
  difficulty    String   @default("beginner")
  description   String   @db.Text
  descriptionFr String   @db.Text
  instructions  String   @db.Text
  instructionsFr String  @db.Text
  durationSec   Int      @default(30)
  targetReps    Int      @default(10)
  icon          String   @default("🎯")
  isActive      Boolean  @default(true) @db.Boolean
  isCustom      Boolean  @default(false) @db.Boolean
  createdAt     DateTime @default(now())

  player              Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  favorites           DrillFavorite[]
  sessions            WorkoutSessionDrill[]
  trainingPlanDrills  TrainingPlanDrill[]

  @@index([playerId])
  @@index([category])
  @@index([playerId, type])
  @@map("drills")
}

model WorkoutSession {
  id               String    @id @default(uuid()) @db.Uuid
  playerId         String    @db.Uuid
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  totalScore       Float     @default(0)
  totalReps        Int       @default(0)
  totalDrills      Int       @default(0)
  totalDurationSec Int       @default(0)
  avgScore         Float     @default(0)
  notes            String?   @db.Text
  isShared         Boolean   @default(false) @db.Boolean
  sharedAt         DateTime?
  videoId          String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drills          WorkoutSessionDrill[]
  sessionComments SessionComment[]
  feedPosts       FeedPost[]   @relation("PostSession")
  postComments    Comment[]    @relation("SessionComment")
  video           Video?    @relation(fields: [videoId], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([startedAt])
  @@index([playerId, startedAt(sort: Desc)])
  @@index([videoId])
  @@map("workout_sessions")
}

model WorkoutSessionDrill {
  id            String   @id @default(uuid()) @db.Uuid
  sessionId     String   @db.Uuid
  drillId       String   @db.Uuid
  reps          Int      @default(0)
  score         Float    @default(0)
  durationMs    Int      @default(0)
  formFeedback  Json     @default({})
  createdAt     DateTime @default(now())

  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  drill       Drill         @relation(fields: [drillId], references: [id])

  @@index([sessionId])
  @@index([drillId])
  @@map("workout_session_drills")
}

model DrillFavorite {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  drillId     String   @db.Uuid
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drill       Drill    @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@unique([playerId, drillId])
  @@index([playerId])
  @@map("drill_favorites")
}

model TrainingPlan {
  id          String    @id @default(uuid()) @db.Uuid
  playerId    String    @db.Uuid
  name        String
  description String?   @db.Text
  isPublic    Boolean   @default(false) @db.Boolean
  isActive    Boolean   @default(true) @db.Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  drills      TrainingPlanDrill[]

  @@index([playerId])
  @@map("training_plans")
}

model TrainingPlanDrill {
  id          String   @id @default(uuid()) @db.Uuid
  planId      String   @db.Uuid
  drillId     String   @db.Uuid
  order       Int      @default(0)
  targetReps  Int      @default(10)
  targetSets  Int      @default(1)
  restSec     Int      @default(30)
  createdAt   DateTime @default(now())

  plan        TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  drill       Drill        @relation(fields: [drillId], references: [id])

  @@unique([planId, drillId])
  @@index([planId])
  @@index([drillId])
  @@map("training_plan_drills")
}

model Achievement {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  type        String
  title       String
  description String   @db.Text
  icon        String
  unlockedAt  DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, type])
  @@index([playerId])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("achievements")
}

model ReactionScore {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  type        String
  reactionMs  Int
  correct     Boolean  @default(true) @db.Boolean
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
  @@index([playerId, type])
  @@map("reaction_scores")
}

model AIChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @db.Uuid
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("ai_chat_messages")
}

model XpLog {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  amount      Int
  source      String
  description String   @db.Text
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("xp_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOCIAL — Friends, Teams, Challenges, Feed, Messaging, Comments, Follow, Live
// ═══════════════════════════════════════════════════════════════════════════════

model Friendship {
  id            String   @id @default(uuid()) @db.Uuid
  requesterId   String   @db.Uuid
  recipientId   String   @db.Uuid
  status        String   @default("pending") // pending, accepted, declined, blocked
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requester     Player   @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient     Player   @relation("ReceivedRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([requesterId])
  @@index([recipientId])
  @@index([status])
  @@index([status, createdAt])
  @@index([requesterId, status])
  @@index([recipientId, status])
  @@map("friendships")
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?   @db.Text
  logo        String?
  sport       String    @default("basketball")
  isPublic    Boolean   @default(true) @db.Boolean
  maxMembers  Int       @default(15)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       Player    @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String    @db.Uuid
  members     TeamMember[]
  challenges  TeamChallenge[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id          String   @id @default(uuid()) @db.Uuid
  teamId      String   @db.Uuid
  playerId    String   @db.Uuid
  role        String   @default("member") // owner, admin, member
  joinedAt    DateTime @default(now())

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
  @@map("team_members")
}

model Challenge {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  description   String    @db.Text
  type          String    // drill_score, total_reps, streak, speed, custom
  targetValue   Int
  unit          String    @default("reps") // reps, points, ms, days
  startDate     DateTime
  endDate       DateTime
  isPublic      Boolean   @default(true) @db.Boolean
  xpReward      Int       @default(100)
  creatorId     String    @db.Uuid
  createdAt     DateTime  @default(now())

  creator       Player    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants  ChallengeParticipant[]
  teamChallenges TeamChallenge[]

  @@index([creatorId])
  @@index([startDate])
  @@index([type])
  @@map("challenges")
}

model ChallengeParticipant {
  id             String   @id @default(uuid()) @db.Uuid
  challengeId    String   @db.Uuid
  playerId       String   @db.Uuid
  currentValue   Int      @default(0)
  completed      Boolean  @default(false) @db.Boolean
  completedAt    DateTime?
  rank           Int?
  joinedAt       DateTime @default(now())

  challenge      Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  player         Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([challengeId, playerId])
  @@index([challengeId])
  @@index([playerId])
  @@map("challenge_participants")
}

model TeamChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  teamId       String   @db.Uuid
  challengeId  String   @db.Uuid
  createdAt    DateTime @default(now())

  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([teamId, challengeId])
  @@index([teamId])
  @@index([challengeId])
  @@map("team_challenges")
}

model FeedPost {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String   @db.Uuid
  content       String   @db.Text
  type          String   @default("text") // text, workout, achievement, challenge, video
  sessionId     String?  @db.Uuid
  videoId       String?  @db.Uuid
  imageUrls     Json     @default([])
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  createdAt     DateTime @default(now())

  player      Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  likes       FeedPostLike[]
  comments    Comment[]
  session     WorkoutSession? @relation("PostSession", fields: [sessionId], references: [id])
  video       Video?           @relation(fields: [videoId], references: [id])

  @@index([playerId])
  @@index([createdAt])
  @@index([playerId, createdAt(sort: Desc)])
  @@index([type])
  @@index([sessionId])
  @@index([videoId])
  @@map("feed_posts")
}

model FeedPostLike {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @db.Uuid
  playerId    String   @db.Uuid
  createdAt   DateTime @default(now())

  post        FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([postId, playerId])
  @@index([postId])
  @@index([playerId])
  @@map("feed_post_likes")
}

model Comment {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  postId      String?  @db.Uuid
  sessionId   String?  @db.Uuid
  content     String   @db.Text
  likesCount  Int      @default(0)
  createdAt   DateTime @default(now())

  player      Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  post        FeedPost?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  session     WorkoutSession?  @relation("SessionComment", fields: [sessionId], references: [id], onDelete: Cascade)
  replies     CommentReply[]

  @@index([playerId])
  @@index([postId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([postId, createdAt])
  @@map("comments")
}

model CommentReply {
  id          String   @id @default(uuid()) @db.Uuid
  commentId   String   @db.Uuid
  playerId    String   @db.Uuid
  content     String   @db.Text
  createdAt   DateTime @default(now())

  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([playerId])
  @@map("comment_replies")
}

model Conversation {
  id             String   @id @default(uuid()) @db.Uuid
  type           String   @default("dm") // dm, group
  name           String?  // for group conversations
  avatar         String?
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  members     ConversationMember[]
  messages    Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  playerId       String   @db.Uuid
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([conversationId, playerId])
  @@index([conversationId])
  @@index([playerId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  senderId       String   @db.Uuid
  content        String   @db.Text
  type           String   @default("text") // text, image, video, workout, system
  metadata       Json     @default({})
  isRead         Boolean  @default(false) @db.Boolean
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         Player       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower    Player   @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   Player   @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model LiveSession {
  id          String    @id @default(uuid()) @db.Uuid
  hostId      String    @db.Uuid
  title       String
  drillId     String?   @db.Uuid
  status      String    @default("waiting") // waiting, active, ended
  maxViewers  Int       @default(10)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime  @default(now())

  host            Player           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  participants    LiveParticipant[]

  @@index([hostId])
  @@index([status])
  @@index([status, createdAt])
  @@index([drillId])
  @@map("live_sessions")
}

model LiveParticipant {
  id            String   @id @default(uuid()) @db.Uuid
  liveSessionId String   @db.Uuid
  playerId      String   @db.Uuid
  joinedAt      DateTime @default(now())
  score         Float    @default(0)
  reps          Int      @default(0)

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, playerId])
  @@index([liveSessionId])
  @@index([playerId])
  @@map("live_participants")
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  type        String   // friend_request, challenge_invite, like, comment, follow, live_start, achievement, system
  title       String
  body        String   @db.Text
  data        Json     @default({})
  isRead      Boolean  @default(false) @db.Boolean
  readAt      DateTime?
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, isRead])
  @@index([playerId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIDEO — Upload, Annotations, Highlights, Comparison, Library, Export, Share
// ═══════════════════════════════════════════════════════════════════════════════

model Video {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String   @db.Uuid
  title         String
  description   String   @default("") @db.Text
  url           String   // storage path/URL
  thumbnailUrl  String?
  durationSec   Int      @default(0)
  fileSize      Int      @default(0) // bytes
  mimeType      String   @default("video/mp4")
  width         Int      @default(0)
  height        Int      @default(0)
  isPublic      Boolean  @default(false) @db.Boolean
  viewCount     Int      @default(0)
  tags          Json     @default([])
  createdAt     DateTime @default(now())

  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  annotations   VideoAnnotation[]
  highlights    VideoHighlight[]
  exports       VideoExport[]
  posts         FeedPost[]
  sessions      WorkoutSession[]

  @@index([playerId])
  @@index([createdAt])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("videos")
}

model VideoAnnotation {
  id          String   @id @default(uuid()) @db.Uuid
  videoId     String   @db.Uuid
  playerId    String   @db.Uuid
  type        String   @default("drawing") // drawing, text, arrow, circle
  data        Json     // {points, color, text, ...}
  timestampMs Int
  durationMs  Int      @default(0)
  createdAt   DateTime @default(now())

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([playerId])
  @@map("video_annotations")
}

model VideoHighlight {
  id          String   @id @default(uuid()) @db.Uuid
  videoId     String   @db.Uuid
  title       String
  startMs     Int
  endMs       Int
  type        String   @default("auto") // auto, manual
  score       Float?
  createdAt   DateTime @default(now())

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("video_highlights")
}

model VideoExport {
  id          String   @id @default(uuid()) @db.Uuid
  videoId     String   @db.Uuid
  playerId    String   @db.Uuid
  type        String   // gif, mp4, webm
  format      String   @default("gif")
  url         String?
  status      String   @default("pending") // pending, processing, completed, failed
  fileSize    Int      @default(0)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([playerId])
  @@index([playerId, videoId])
  @@index([status, createdAt])
  @@map("video_exports")
}

model SessionComment {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @db.Uuid
  playerId    String   @db.Uuid
  content     String   @db.Text
  timestampMs Int?
  createdAt   DateTime @default(now())

  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([playerId])
  @@map("session_comments")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI — Pose tracking, Shot detection, Form scoring, RAG, Voice, Predictions
// ═══════════════════════════════════════════════════════════════════════════════

model PoseData {
  id              String   @id @default(uuid()) @db.Uuid
  playerId        String   @db.Uuid
  sessionId       String?  @db.Uuid
  drillId         String?  @db.Uuid
  landmarks       Json     // MediaPipe landmarks
  frameTimestamp  Int      // ms
  confidence      Float    @default(0)
  createdAt       DateTime @default(now())

  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([sessionId])
  @@index([drillId])
  @@index([sessionId, drillId])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("pose_data")
}

model ShotDetection {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String   @db.Uuid
  sessionId     String?  @db.Uuid
  videoId       String?  @db.Uuid
  type          String   // made, missed, airball, bank
  x             Float
  y             Float
  confidence    Float
  timestampMs   Int
  formScore     Float?
  createdAt     DateTime @default(now())

  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([sessionId])
  @@index([videoId])
  @@index([playerId, sessionId])
  @@index([playerId, type])
  @@map("shot_detections")
}

model FormAnalysis {
  id              String   @id @default(uuid()) @db.Uuid
  playerId        String   @db.Uuid
  sessionId       String?  @db.Uuid
  drillId         String?  @db.Uuid
  overallScore    Float
  rating          Float    @default(0)
  kneeScore       Float?
  elbowScore      Float?
  trunkScore      Float?
  balanceScore    Float?
  alignmentScore  Float?
  categories      Json     // {stance: 0.8, release: 0.9, follow_through: 0.7}
  feedback        Json     // {good: [...], issues: [...], tips: [...]}
  poseDataId      String?  @db.Uuid
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([sessionId])
  @@index([drillId])
  @@index([poseDataId])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("form_analyses")
}

model PlayerInsight {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String   @db.Uuid
  category      String   // strength, weakness, trend, recommendation
  title         String
  description   String   @db.Text
  confidence    Float
  data          Json     @default({})
  period        String   @default("week") // day, week, month, all
  createdAt     DateTime @default(now())

  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([category])
  @@index([playerId, type])
  @@map("player_insights")
}

model PlayerDocument {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  type        String   // session_summary, stats_snapshot, achievement_record, form_report
  content     String   @db.Text
  metadata    Json     @default({})
  embedding   String?  @db.Text // vector embedding (base64; consider pgvector in future)
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([type])
  @@map("player_documents")
}

model VoiceSession {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  sessionId   String?  @db.Uuid
  audioUrl    String?
  transcript  String   @default("") @db.Text
  language    String   @default("fr")
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([sessionId])
  @@map("voice_sessions")
}

model Prediction {
  id              String   @id @default(uuid()) @db.Uuid
  playerId        String   @db.Uuid
  type            String   // next_level, injury_risk, performance, plateau
  predictedAt     DateTime
  predictedValue  Float?
  confidence      Float
  factors         Json     @default([])
  recommendation  String   @db.Text
  createdAt       DateTime @default(now())

  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([type])
  @@index([playerId, type])
  @@map("predictions")
}

model GeneratedWorkout {
  id            String   @id @default(uuid()) @db.Uuid
  playerId      String   @db.Uuid
  title         String
  description   String   @db.Text
  difficulty    String   @default("intermediate")
  durationMin   Int      @default(30)
  focusAreas    Json     @default([]) // ["shooting", "ball_handling"]
  drillIds      Json     @default([]) // [drillId, ...]
  aiReasoning   String   @default("") @db.Text
  isUsed        Boolean  @default(false) @db.Boolean
  createdAt     DateTime @default(now())

  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([playerId, createdAt(sort: Desc)])
  @@map("generated_workouts")
}

// ═══════════════════════════════════════════════════════════════════════════════
// CORE — Email verification, 2FA, Devices, Offline sync
// ═══════════════════════════════════════════════════════════════════════════════

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false) @db.Boolean
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([playerId])
  @@map("email_verification_tokens")
}

model TwoFactorBackupCode {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @db.Uuid
  code      String
  used      Boolean  @default(false) @db.Boolean
  usedAt    DateTime?
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([code])
  @@map("two_factor_backup_codes")
}

model Device {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  name        String   // e.g. "iPhone 15", "Chrome Desktop"
  type        String   // mobile, tablet, desktop
  os          String   @default("")
  appVersion  String   @default("")
  pushToken   String?  // for push notifications
  lastActive  DateTime @default(now())
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("devices")
}

model DailyLogin {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  date        String
  xpAwarded   Int
  createdAt   DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date])
  @@index([playerId])
  @@map("daily_logins")
}

model OfflineAction {
  id          String   @id @default(uuid()) @db.Uuid
  playerId    String   @db.Uuid
  deviceId    String
  type        String   // session_save, drill_favorite, post_create, etc.
  payload     Json
  status      String   @default("pending") // pending, synced, failed
  createdAt   DateTime @default(now())
  syncedAt    DateTime?

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([status])
  @@index([createdAt])
  @@index([deviceId])
  @@index([playerId, status])
  @@index([status, createdAt])
  @@map("offline_actions")
}