# ===========================================
# CourtVision AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# ---- Database ----
# SQLite file path. In Docker this becomes file:/app/db/courtvision.db
DATABASE_URL="file:./db/courtvision.db"

# ---- NextAuth ----
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ---- AI SDK ----
# z-ai-web-dev-sdk is auto-configured in the development environment.
# For production, set the key if required by your provider:
# ZAI_API_KEY=...

# ---- Optional: External Services ----
# Sentry error tracking
# SENTRY_DSN=...

# Stripe payments (future feature)
# STRIPE_SECRET_KEY=...
# STRIPE_PUBLISHABLE_KEY=...
# STRIPE_WEBHOOK_SECRET=...

# Web Push notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=...
# VAPID_PUBLIC_KEY=...
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...