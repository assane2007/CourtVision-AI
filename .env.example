# ═══════════════════════════════════════════════════════════════════
# CourtVision AI — Complete Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
#
# Variables marked [REQUIRED] must be set in production.
# Variables marked [OPTIONAL] have sensible defaults.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ═══════════════════════════════════════════════════════════════════

# ─── General ─────────────────────────────────────────────────────
NODE_ENV=development                    # development | production
PORT=3000
HOSTNAME=0.0.0.0

# ─── Database ────────────────────────────────────────────────────
# [REQUIRED] SQLite (dev) or PostgreSQL (prod)
# Dev:   DATABASE_URL="file:./db/courtvision.db"
# Prod:  DATABASE_URL="postgresql://user:pass@host:5432/courtvision"
DATABASE_URL="file:./db/courtvision.db"

# ─── Authentication ─────────────────────────────────────────────
# [REQUIRED in prod] Generate: openssl rand -base64 48
NEXTAUTH_SECRET="change-me-in-production-minimum-32-chars!!"
# [REQUIRED in prod] Public URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
# [OPTIONAL] Separate JWT secret (falls back to NEXTAUTH_SECRET)
# JWT_SECRET=""

# ─── Sentry Error Tracking ──────────────────────────────────────
# [OPTIONAL] Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Set to "false" to explicitly disable
NEXT_PUBLIC_SENTRY_ENABLED=true
# [OPTIONAL] Release version for better error grouping
# NEXT_PUBLIC_SENTRY_RELEASE=courtvision-ai@1.0.0
# [BUILD ONLY] Auth token for source map upload
# SENTRY_AUTH_TOKEN=

# ─── Stripe Payments ────────────────────────────────────────────
# [OPTIONAL] Leave empty to disable payments
STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Redis Cache ────────────────────────────────────────────────
# [OPTIONAL] Set to enable Redis (cache + rate limiter)
# Without this, uses in-memory cache (single instance only)
# REDIS_URL="redis://localhost:6379"

# ─── S3 / Cloud Storage ────────────────────────────────────────
# [OPTIONAL] Set S3_BUCKET to use cloud storage; otherwise uses local filesystem
# S3_BUCKET=courtvision-videos
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=                   # Custom endpoint (Wasabi, R2, MinIO)

# ─── Security ───────────────────────────────────────────────────
# [AUTO-GENERATED in dev] 32-byte encryption key for sensitive data
# ENCRYPTION_KEY=
# [OPTIONAL] Comma-separated CORS origins (dev allows all)
# ALLOWED_ORIGINS=https://courtvision.app,https://app.courtvision.app
# [DEV ONLY] Set "true" to expose password reset tokens in API responses
# DEV_SHOW_RESET_TOKEN=false

# ─── Push Notifications (VAPID) ────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Email ──────────────────────────────────────────────────────
# [OPTIONAL] Public URL used in email templates
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [OPTIONAL] Resend API key for transactional emails
# RESEND_API_KEY=

# ─── Logging & Debugging ───────────────────────────────────────
# [OPTIONAL] Override log level: debug | info | warn | error | fatal
# LOG_LEVEL=info
# [OPTIONAL] Log all database queries (dev only)
# LOG_QUERIES=true