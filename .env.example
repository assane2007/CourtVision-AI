# ===========================================
# CourtVision AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# ---- Database ----
# SQLite file path. In Docker this becomes file:/app/db/courtvision.db
DATABASE_URL="file:./db/courtvision.db"

# ---- NextAuth ----
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ---- AI SDK ----
# z-ai-web-dev-sdk is auto-configured in the development environment.
# For production, set the key if required by your provider:
# ZAI_API_KEY=...

# ---- Sentry Error Tracking ----
# Client-side DSN (public, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (secret, used by API routes and server components)
SENTRY_DSN=
# Source map upload auth token (build-time only)
# SENTRY_AUTH_TOKEN=
# Optional: Set a release version for better error grouping
# NEXT_PUBLIC_SENTRY_RELEASE=courtvision-ai@1.0.0

# ---- Stripe Payments ----

# Stripe payments (production)
# STRIPE_SECRET_KEY=...
# STRIPE_PUBLISHABLE_KEY=...
# STRIPE_WEBHOOK_SECRET=...

# Web Push notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=...
# VAPID_PUBLIC_KEY=...
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...