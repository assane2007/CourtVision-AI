{
  "name": "courtvision-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.1",
    "fastify": "^5.8.4",
    "fast-jwt": "^6.2.2",
    "@tootallnate/once": "^3.0.1"
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "check:placeholders": "node scripts/check-placeholders.js",
    "check:mobile:release": "node scripts/check-mobile-release.js",
    "typecheck": "npm run typecheck:shared && npm run typecheck:ai && npm run typecheck:api && npm run typecheck:web && npm run typecheck:mobile",
    "typecheck:shared": "npm -w @courtvision/shared run build",
    "typecheck:ai": "npm -w @courtvision/ai run build",
    "typecheck:api": "npm -w @courtvision/api run build",
    "typecheck:web": "npm -w @courtvision/web exec tsc -- --noEmit",
    "typecheck:mobile": "npm -w @courtvision/mobile exec tsc -- --noEmit",
    "test": "npm run test:shared && npm run test:api && npm run test:ai && npm run test:mobile",
    "test:shared": "npm -w @courtvision/shared run test",
    "test:api": "npm -w @courtvision/api run test",
    "test:ai": "npm -w @courtvision/ai run test",
    "test:mobile": "npm -w @courtvision/mobile run test",
    "dev:web": "npm -w @courtvision/web run dev",
    "dev:api": "npm -w @courtvision/api run dev",
    "build": "npm run build:shared && npm run build:ai && npm run build:api && npm run build:web",
    "build:shared": "npm -w @courtvision/shared run build",
    "build:web": "npm -w @courtvision/web run build",
    "build:api": "npm -w @courtvision/api run build",
    "build:ai": "npm -w @courtvision/ai run build",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "validate": "python scripts/validate_skills.py",
    "build:index": "python scripts/build_index.py",
    "stats": "python scripts/validate_skills.py",
    "health:mobile": "powershell -ExecutionPolicy Bypass -File scripts/release/check-mobile-runtime.ps1",
    "tunnel:named:start": "powershell -ExecutionPolicy Bypass -File scripts/release/start-named-tunnels.ps1 -UpdateMobileEnv",
    "tunnel:named:status": "powershell -ExecutionPolicy Bypass -File scripts/release/status-named-tunnels.ps1",
    "tunnel:named:stop": "powershell -ExecutionPolicy Bypass -File scripts/release/stop-named-tunnels.ps1",
    "health:backend-cv": "powershell -ExecutionPolicy Bypass -File scripts/release/check-backend-cv-runtime.ps1",
    "health:backend-cv:dev": "powershell -ExecutionPolicy Bypass -File scripts/release/check-backend-cv-runtime.ps1 -AllowDegradedApi -AllowDatabaseUnavailable -AllowWarmingCv -AllowNbaUnavailable"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-module-scripts": "^55.0.2",
    "prettier": "^3.2.5",
    "react-native-worklets": "^0.5.1",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@supabase/supabase-js": "^2.39.8",
    "ajv": "^8.18.0",
    "expo-sharing": "^55.0.11",
    "react-native-get-random-values": "~1.11.0",
    "react-native-view-shot": "^4.0.3",
    "resolve-from": "^5.0.0"
  }
}
