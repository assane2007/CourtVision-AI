{
  "name": "courtvision-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@courtvision/mobile": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:api && npm run test:ai",
    "test:api": "npm -w @courtvision/api run test",
    "test:ai": "npm -w @courtvision/ai run test",
    "dev:web": "npm -w @courtvision/web run dev",
    "dev:api": "npm -w @courtvision/api run dev",
    "build": "npm run build:shared && npm run build:ai && npm run build:api && npm run build:web",
    "build:shared": "npm -w @courtvision/shared run build",
    "build:web": "npm -w @courtvision/web run build",
    "build:api": "npm -w @courtvision/api run build",
    "build:ai": "npm -w @courtvision/ai run build",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "validate": "python scripts/validate_skills.py",
    "build:index": "python scripts/build_index.py",
    "stats": "python scripts/validate_skills.py"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.2.5",
    "react-native-worklets": "^0.5.1",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@supabase/supabase-js": "^2.39.8",
    "ajv": "^8.18.0",
    "react-native-get-random-values": "~1.11.0",
    "resolve-from": "^5.0.0"
  }
}
