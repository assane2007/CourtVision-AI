# Copy this file to scripts/release/.named-tunnels.env and fill values.
# Do not commit the real .named-tunnels.env file.

# Optional absolute path to cloudflared executable.
# Leave empty to use cloudflared from PATH or default install locations.
CLOUDFLARED_BIN=

# Cloudflare named tunnel run tokens (one token per tunnel process).
API_TUNNEL_TOKEN=
CV_TUNNEL_TOKEN=

# Stable public hostnames mapped to those named tunnels.
API_PUBLIC_URL=https://api-mobile-dev.example.com
CV_PUBLIC_URL=https://cv-mobile-dev.example.com
