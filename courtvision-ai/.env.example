# ============================================================
# CourtVision AI — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ============================================================

# === CORE ===
NODE_ENV=development                   # development | production | test
PORT=8080                              # API server port (MUST match Dockerfile & docker-compose)

# === SUPABASE (required) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...               # Anon/public key (safe for client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Service role key (server-side only, NEVER expose)

# === AUTH — Apple Sign-In ===
APPLE_CLIENT_ID=com.yourcompany.courtvision
APPLE_TEAM_ID=XXXXXXXXXX

# === AUTH — Google Sign-In ===
GOOGLE_CLIENT_ID_IOS=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=xxxx.apps.googleusercontent.com

# === PAYMENTS — Stripe ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLAYER=price_...          # Player plan ($9/mo)
STRIPE_PRICE_COACH=price_...           # Coach plan ($29/mo)
STRIPE_PRICE_ACADEMY=price_...         # Academy plan ($99/mo)

# === PAYMENTS — RevenueCat (mobile IAP) ===
REVENUECAT_WEBHOOK_SECRET=whsec_...

# === AI / LLM ===
GEMINI_API_KEY=AIzaSy_...              # Google Gemini API key (primary cloud model)
GEMINI_MODEL=gemini-2.0-flash
LLM_FREE_ONLY=false                     # true = skip Gemini and use free fallbacks only
CLOUDFLARE_ACCOUNT_ID=...              # Cloudflare Workers AI account
CLOUDFLARE_API_TOKEN=...               # Cloudflare AI API token
# Legacy alias (optional):
# CLOUDFLARE_AI_TOKEN=...
OLLAMA_BASE_URL=http://localhost:11434 # Local Ollama instance (fallback)
OLLAMA_MODEL=llama3.2

# === VOICE / TTS ===
COQUI_MODEL=tts_models/fr/css10/vits

# === CV ENGINE (Python FastAPI) ===
CV_ENGINE_URL=http://localhost:8000

# === REDIS (BullMQ queues) ===
REDIS_URL=redis://localhost:6379

# === MONITORING ===
SENTRY_DSN=https://xxx@sentry.io/xxx
POSTHOG_API_KEY=phc_...

# === SECURITY ===
JWT_SECRET=your-secret-key-here        # Minimum 256-bit random secret
ENCRYPTION_KEY=                        # AES-256-GCM key (64 hex chars)

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,https://courtvision.ai

# === FEATURE FLAGS ===
ENABLE_SPATIAL_3D=false                # 3D Gaussian Splatting (requires A100 GPU)
ENABLE_TIKTOK=false                    # TikTok sharing (Business API approval needed)
ENABLE_VOICE_COACH=false               # Voice coaching WebSocket (experimental)
ENABLE_PRECOG=true                     # Pre-Cog reaction training

# === TIKTOK (when ENABLE_TIKTOK=true) ===
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://courtvision.ai/api/tiktok/callback
TIKTOK_LINK_SIMULATION_ENABLED=false   # Keep false in production until real OAuth callback flow is live

# === WEB FRONTEND (apps/web/.env.local) ===
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_ENABLE_MOCK_UI=false       # Enables NeuralHUD + SimulationTerminal only outside production
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
