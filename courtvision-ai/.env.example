# ==========================================
# CourtVision AI — Environment Variables
# ==========================================

# Supabase (https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLAYER=price_...
STRIPE_PRICE_COACH=price_...
STRIPE_PRICE_ACADEMY=price_...

# Groq — Free LLM API (https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — Local LLM fallback (https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Coqui TTS — Open source text-to-speech
COQUI_MODEL=tts_models/fr/css10/vits

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Application
JWT_SECRET=your-secret-key-here
NODE_ENV=development
PORT=3001

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
