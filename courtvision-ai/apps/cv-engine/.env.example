# CourtVision CV Engine — Environment Variables
# Copy to .env and fill in values

# Number of worker threads for ML inference (default: 2)
CV_WORKERS=2

# YOLOv8 model file (downloaded automatically at startup)
# Options: yolov8n.pt (nano/fast), yolov8s.pt (small/balanced), yolov8m.pt (medium/accurate)
YOLO_MODEL=yolov8s.pt

# Port (Railway sets this automatically)
PORT=8000
